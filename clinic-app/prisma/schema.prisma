generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// LOOKUP TABLES
// ============================================

model Disease {
  id        Int              @id @default(autoincrement())
  code      String           @unique // legacy DI_CODE
  name      String
  createdAt DateTime         @default(now())
  patients  PatientDisease[]

  @@map("diseases")
}

model Operation {
  id                  Int              @id @default(autoincrement())
  code                Int?             @unique
  name                String
  category            String?
  defaultMinFee       Float?
  defaultMaxFee       Float?
  doctorFee           Float?           // fixed doctor fee per procedure (e.g. RCT = ₹1,800)
  labCostEstimate     Float?           // typical lab cost, used for minimum collection warnings
  suggestsOperationId Int?             // auto-suggest linked treatment (e.g. RCT → Crown)
  suggestsOperation   Operation?       @relation("OperationSuggestion", fields: [suggestsOperationId], references: [id])
  suggestedBy         Operation[]      @relation("OperationSuggestion")
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  visits              Visit[]
  treatmentSteps      TreatmentStep[]
  planItems           TreatmentPlanItem[]
  workDoneEntries     WorkDone[]

  @@map("operations")
}

model TreatmentStep {
  id              Int       @id @default(autoincrement())
  operationId     Int
  operation       Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  stepNumber      Int
  name            String
  description     String?
  noteTemplate    String?
  defaultDayGap   Int       @default(7)
  defaultDoctorId Int?
  defaultDoctor   Doctor?   @relation("DefaultTreatmentStepDoctor", fields: [defaultDoctorId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([operationId, stepNumber])
  @@map("treatment_steps")
}

model Lab {
  id           Int       @id @default(autoincrement())
  code         Int?      @unique
  name         String
  contactPhone String?
  contactEmail String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  rates        LabRate[]
  visits       Visit[]

  @@map("labs")
}

model LabRate {
  id        Int      @id @default(autoincrement())
  labId     Int
  lab       Lab      @relation(fields: [labId], references: [id])
  itemCode  Int // legacy LR_CODE within lab
  itemName  String
  rate      Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  visits    Visit[]
  planItems TreatmentPlanItem[]

  @@unique([labId, itemCode])
  @@map("lab_rates")
}

model Designation {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  doctors   Doctor[]

  @@map("designations")
}

model Room {
  id           Int           @id @default(autoincrement())
  name         String
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments   Appointment[]
  defaultDoctors Doctor[]       @relation("DefaultRoom")

  @@map("rooms")
}

model DoctorAvailability {
  id        Int    @id @default(autoincrement())
  doctorId  Int
  dayOfWeek Int    // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime String // "10:00" (24h format)
  endTime   String // "14:00"
  doctor    Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@index([doctorId])
  @@map("doctor_availability")
}

// ============================================
// CORE TABLES
// ============================================

model ClinicSettings {
  id           Int      @id @default(autoincrement())
  name         String
  addressLine1 String?
  addressLine2 String?
  addressLine3 String?
  city         String?
  state        String?
  pincode      String?
  phone        String?
  fax          String?
  email        String?
  gstNumber    String?
  scanFolder   String?
  appVersion   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("clinic_settings")
}

model Doctor {
  id                Int                      @id @default(autoincrement())
  code              Int?                     @unique
  name              String
  mobile            String?
  email             String?
  designationId     Int?
  designation       Designation?             @relation(fields: [designationId], references: [id])
  commissionPercent Float                    @default(0)
  commissionRate    Float?
  tdsPercent        Float                    @default(0)
  tdsNew            Float?
  tdsDate           DateTime?
  permissionLevel   Int                      @default(3)
  password          String?
  specialty         String?
  isSuperUser       Boolean                  @default(false)
  isConsultant      Boolean                  @default(false)
  defaultRoomId     Int?
  defaultRoom       Room?                    @relation("DefaultRoom", fields: [defaultRoomId], references: [id])
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  commissionHistory DoctorCommissionHistory[]
  visits            Visit[]                  @relation("PrimaryDoctor")
  assistedVisits    Visit[]                  @relation("AssistingDoctor")
  receiptsCreated   Receipt[]
  clinicalReports   ClinicalReport[]
  lockedReports        ClinicalReport[]   @relation("LockedReports")
  addendums            ClinicalAddendum[]
  uploadedFiles        PatientFile[]
  appointmentsAsDoctor Appointment[]      @relation("AppointmentDoctor")
  appointmentsCreated  Appointment[]      @relation("AppointmentCreatedBy")
  createdPlans         TreatmentPlan[]    @relation("CreatedPlans")
  assignedPlanItems    TreatmentPlanItem[] @relation("AssignedPlanItems")
  availability         DoctorAvailability[]
  defaultStepDoctors   TreatmentStep[]        @relation("DefaultTreatmentStepDoctor")
  auditLogs            AuditLog[]
  toothStatusHistory   ToothStatusHistory[]
  workDoneEntries      WorkDone[]
  prescriptionsCreated Prescription[]  @relation("PrescriptionDoctor")
  prescriptionsPrinted Prescription[]  @relation("PrescriptionPrintedBy")
  payments             PatientPayment[]
  escrowFulfillments   EscrowFulfillment[]
  modifiedPlanItems    TreatmentPlanItem[] @relation("ModifiedPlanItems")
  createdChains        TreatmentChain[]    @relation("CreatedChains")
  clinicalNotes        ClinicalNote[]      @relation("ClinicalNotesAuthored")

  @@map("doctors")
}

model DoctorCommissionHistory {
  id                Int      @id @default(autoincrement())
  doctorId          Int
  doctor            Doctor   @relation(fields: [doctorId], references: [id])
  periodFrom        DateTime
  periodTo          DateTime
  commissionPercent Float?
  commissionRate    Float?
  createdAt         DateTime @default(now())

  @@map("doctor_commission_history")
}

model Patient {
  id                  Int              @id @default(autoincrement())
  code                Int?             @unique
  salutation          String?
  name                String
  fatherHusbandName   String?
  dateOfBirth         DateTime?
  ageAtRegistration   Int?
  gender              String?
  bloodGroup          String?
  occupation          String?
  phone               String?
  mobile              String?
  email               String?
  addressLine1        String?
  addressLine2        String?
  addressLine3        String?
  city                String?
  pincode             String?
  referringPhysician  String?
  physicianPhone      String?
  remarks             String?
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  diseases            PatientDisease[]
  visits              Visit[]
  files               PatientFile[]
  appointments        Appointment[]
  treatmentPlans      TreatmentPlan[]
  toothStatuses       ToothStatus[]
  toothStatusHistory  ToothStatusHistory[]
  prescriptions       Prescription[]
  payments            PatientPayment[]
  escrowFulfillments  EscrowFulfillment[]
  treatmentChains     TreatmentChain[]
  clinicalNotes       ClinicalNote[]

  @@map("patients")
}

model PatientDisease {
  id        Int      @id @default(autoincrement())
  patientId Int
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  diseaseId Int
  disease   Disease  @relation(fields: [diseaseId], references: [id])
  notedDate DateTime?
  createdAt DateTime @default(now())

  @@unique([patientId, diseaseId])
  @@map("patient_diseases")
}

model Visit {
  id                      Int              @id @default(autoincrement())
  caseNo                  Int?             @unique
  patientId               Int
  patient                 Patient          @relation(fields: [patientId], references: [id])
  visitDate               DateTime
  visitType               String           @default("NEW") // "NEW", "FOLLOWUP", "REVIEW"
  parentVisitId           Int?
  parentVisit             Visit?           @relation("FollowUps", fields: [parentVisitId], references: [id])
  followUps               Visit[]          @relation("FollowUps")
  stepLabel               String?
  customLabel             String?          // Overrides operation name in displays
  followUpReason          String?          // "REDO" | "COMPLICATION" | "ADJUSTMENT" | null
  operationId             Int?
  operation               Operation?       @relation(fields: [operationId], references: [id])
  operationRate           Float?
  discount                Float            @default(0)
  discountReason          String?
  quantity                Int              @default(1)
  doctorId                Int?
  doctor                  Doctor?          @relation("PrimaryDoctor", fields: [doctorId], references: [id])
  assistingDoctorId       Int?
  assistingDoctor         Doctor?          @relation("AssistingDoctor", fields: [assistingDoctorId], references: [id])
  doctorCommissionPercent Float?
  doctorCommissionAmount  Float?
  labId                   Int?
  lab                     Lab?             @relation(fields: [labId], references: [id])
  labRateId               Int?
  labRate                 LabRate?         @relation(fields: [labRateId], references: [id])
  labRateAmount           Float            @default(0)
  labQuantity             Float            @default(1)
  notes                   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  receipts                Receipt[]
  clinicalReports         ClinicalReport[]
  files                   PatientFile[]
  appointments            Appointment[]
  planItems               TreatmentPlanItem[]
  toothStatuses           ToothStatus[]
  toothStatusHistory      ToothStatusHistory[]
  workDone                WorkDone[]
  prescriptions           Prescription[]
  escrowFulfillments      EscrowFulfillment[]
  clinicalNotes           ClinicalNote[]

  @@map("visits")
}

model Receipt {
  id              Int      @id @default(autoincrement())
  receiptNo       Int?
  visitId         Int
  visit           Visit    @relation(fields: [visitId], references: [id])
  receiptDate     DateTime
  amount          Float
  paymentMode     String   @default("Cash") // Cash, Card, Cheque, NEFT, UPI
  isDuplicate     Boolean  @default(false)
  notes           String?
  createdById     Int?
  createdBy       Doctor?  @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())

  @@map("receipts")
}

model ClinicalReport {
  id             Int                @id @default(autoincrement())
  visitId        Int
  visit          Visit              @relation(fields: [visitId], references: [id])
  reportDate     DateTime
  doctorId       Int
  doctor         Doctor             @relation(fields: [doctorId], references: [id])
  complaint      String?
  examination    String?
  diagnosis      String?
  treatmentNotes String?
  estimate       String?
  medication     String?
  teethSelected  String?            // JSON array of FDI tooth numbers, e.g. "[36, 37]"
  lockedAt       DateTime?
  lockedById     Int?
  lockedBy       Doctor?            @relation("LockedReports", fields: [lockedById], references: [id])
  addendums      ClinicalAddendum[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([visitId])
  @@map("clinical_reports")
}

model ClinicalAddendum {
  id               Int            @id @default(autoincrement())
  clinicalReportId Int
  clinicalReport   ClinicalReport @relation(fields: [clinicalReportId], references: [id], onDelete: Cascade)
  doctorId         Int
  doctor           Doctor         @relation(fields: [doctorId], references: [id])
  content          String
  createdAt        DateTime       @default(now())

  @@map("clinical_addendums")
}

model Appointment {
  id           Int      @id @default(autoincrement())
  patientId    Int
  patient      Patient  @relation(fields: [patientId], references: [id])
  doctorId     Int?
  doctor       Doctor?  @relation("AppointmentDoctor", fields: [doctorId], references: [id])
  visitId      Int?
  visit        Visit?   @relation(fields: [visitId], references: [id])
  planItemId   Int?
  planItem     TreatmentPlanItem? @relation(fields: [planItemId], references: [id])
  roomId       Int?
  room         Room?    @relation(fields: [roomId], references: [id])
  date         DateTime
  timeSlot     String?  // free text: "10:00 AM", "2:30 PM", "morning"
  status       String   @default("SCHEDULED") // SCHEDULED, ARRIVED, IN_PROGRESS, COMPLETED, CANCELLED, NO_SHOW
  reason       String?
  notes        String?
  cancelReason String?
  isWalkIn     Boolean  @default(false)
  createdById  Int?
  createdBy    Doctor?  @relation("AppointmentCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  payments     PatientPayment[]

  @@index([date])
  @@index([doctorId, date])
  @@index([patientId])
  @@index([roomId, date])
  @@map("appointments")
}

model PatientFile {
  id            Int      @id @default(autoincrement())
  patientId     Int
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visitId       Int?
  visit         Visit?   @relation(fields: [visitId], references: [id])
  filePath      String
  fileName      String?
  description   String?
  fileType      String?
  category      String   @default("OTHER")
  uploadedById  Int?
  uploadedBy    Doctor?  @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())

  @@map("patient_files")
}

// ============================================
// TREATMENT CHAINS (group related plans: RCT → Crown)
// ============================================

model TreatmentChain {
  id            Int              @id @default(autoincrement())
  patientId     Int
  patient       Patient          @relation(fields: [patientId], references: [id])
  title         String           // "Tooth 36 Treatment"
  toothNumbers  String?          // comma-separated: "36" or "36,37"
  status        String           @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  createdById   Int
  createdBy     Doctor           @relation("CreatedChains", fields: [createdById], references: [id])
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  plans         TreatmentPlan[]
  clinicalNotes ClinicalNote[]

  @@index([patientId])
  @@map("treatment_chains")
}

// ============================================
// CLINICAL NOTES (the notepad — append-only free text)
// ============================================

model ClinicalNote {
  id        Int              @id @default(autoincrement())
  patientId Int
  patient   Patient          @relation(fields: [patientId], references: [id])
  visitId   Int?
  visit     Visit?           @relation(fields: [visitId], references: [id])
  chainId   Int?
  chain     TreatmentChain?  @relation(fields: [chainId], references: [id])
  doctorId  Int
  doctor    Doctor           @relation("ClinicalNotesAuthored", fields: [doctorId], references: [id])
  content   String           // free-text note
  noteDate  DateTime         @default(now())
  createdAt DateTime         @default(now())

  @@index([patientId])
  @@index([chainId])
  @@map("clinical_notes")
}

// ============================================
// TREATMENT PLANS
// ============================================

model TreatmentPlan {
  id             Int                 @id @default(autoincrement())
  patientId      Int
  patient        Patient             @relation(fields: [patientId], references: [id])
  chainId        Int?                // optional — links plan to a treatment chain
  chain          TreatmentChain?     @relation(fields: [chainId], references: [id])
  chainOrder     Int?                // order within chain (1, 2, 3...)
  title          String              // "RCT + Crown tooth 36" — auto-generated or custom
  status         String              @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  estimatedTotal Float?              // cached sum of item costs
  createdById    Int
  createdBy      Doctor              @relation("CreatedPlans", fields: [createdById], references: [id])
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  items          TreatmentPlanItem[]

  @@index([patientId])
  @@index([chainId])
  @@map("treatment_plans")
}

model TreatmentPlanItem {
  id               Int            @id @default(autoincrement())
  planId           Int
  plan             TreatmentPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  sortOrder        Int
  label            String         // "Access Opening", "Crown Prep", or custom text
  operationId      Int?           // optional — links to Operation for pricing
  operation        Operation?     @relation(fields: [operationId], references: [id])
  assignedDoctorId Int?           // optional — which doctor should do this step
  assignedDoctor   Doctor?        @relation("AssignedPlanItems", fields: [assignedDoctorId], references: [id])
  estimatedDayGap  Int            @default(7)
  estimatedCost    Float?         // snapshot of operation fee at plan creation
  estimatedLabCost Float?         // snapshot of lab cost
  labRateId        Int?           // specific lab material chosen
  labRate          LabRate?       @relation(fields: [labRateId], references: [id])
  scheduledDate    DateTime?      // manually editable target date
  visitId          Int?           // set when completed — the visit that fulfilled this item
  visit            Visit?         @relation(fields: [visitId], references: [id])
  completedAt      DateTime?
  notes            String?
  modifiedStatus   String?        // "CHANGED" | "NOT_APPLICABLE"
  modifiedReason   String?
  modifiedById     Int?
  modifiedBy       Doctor?        @relation("ModifiedPlanItems", fields: [modifiedById], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  appointments     Appointment[]
  workDoneEntries  WorkDone[]

  @@index([planId])
  @@map("treatment_plan_items")
}

// ============================================
// DENTAL ODONTOGRAM
// ============================================

model ToothFinding {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  category      String?       // "Caries", "Periodontal", "Structural", "Prosthetic", "Other"
  color         String?       // hex color for chart display
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  toothStatuses      ToothStatus[]
  toothStatusHistory ToothStatusHistory[]

  @@map("tooth_findings")
}

model ToothStatus {
  id           Int           @id @default(autoincrement())
  patientId    Int
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  toothNumber  Int           // FDI: 11-18, 21-28, 31-38, 41-48
  status       String        @default("HEALTHY") // HEALTHY|CARIES|FILLED|CROWNED|MISSING|RCT|IMPLANT|EXTRACTED
  findingId    Int?
  finding      ToothFinding? @relation(fields: [findingId], references: [id])
  notes        String?
  reportedById Int?
  reportedAt   DateTime?
  visitId      Int?
  visit        Visit?        @relation(fields: [visitId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([patientId, toothNumber])
  @@index([patientId])
  @@map("tooth_statuses")
}

model ToothStatusHistory {
  id           Int           @id @default(autoincrement())
  patientId    Int
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  toothNumber  Int
  status       String
  findingId    Int?
  finding      ToothFinding? @relation(fields: [findingId], references: [id])
  notes        String?
  visitId      Int?
  visit        Visit?        @relation(fields: [visitId], references: [id])
  recordedById Int
  recordedBy   Doctor        @relation(fields: [recordedById], references: [id])
  recordedAt   DateTime      @default(now())

  @@index([patientId, toothNumber])
  @@map("tooth_status_history")
}

// ============================================
// WORK DONE (per-tooth per-visit procedures)
// ============================================

model WorkDone {
  id              Int                @id @default(autoincrement())
  visitId         Int
  visit           Visit              @relation(fields: [visitId], references: [id])
  operationId     Int
  operation       Operation          @relation(fields: [operationId], references: [id])
  toothNumber     Int?
  resultingStatus String?
  planItemId      Int?
  planItem        TreatmentPlanItem? @relation(fields: [planItemId], references: [id])
  notes           String?
  performedById   Int
  performedBy     Doctor             @relation(fields: [performedById], references: [id])
  createdAt       DateTime           @default(now())
  fulfillment     EscrowFulfillment?

  @@index([visitId])
  @@index([planItemId])
  @@map("work_done")
}

// ============================================
// PRESCRIPTIONS
// ============================================

model Prescription {
  id          Int                @id @default(autoincrement())
  visitId     Int
  visit       Visit              @relation(fields: [visitId], references: [id])
  doctorId    Int
  doctor      Doctor             @relation("PrescriptionDoctor", fields: [doctorId], references: [id])
  patientId   Int
  patient     Patient            @relation(fields: [patientId], references: [id])
  isPrinted   Boolean            @default(false)
  printedAt   DateTime?
  printedById Int?
  printedBy   Doctor?            @relation("PrescriptionPrintedBy", fields: [printedById], references: [id])
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  items       PrescriptionItem[]

  @@index([visitId])
  @@index([isPrinted])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             Int          @id @default(autoincrement())
  prescriptionId Int
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  sortOrder      Int          @default(1)
  drug           String
  dosage         String?
  frequency      String?
  duration       String?
  instructions   String?

  @@index([prescriptionId])
  @@map("prescription_items")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String   // LARGE_DISCOUNT, OPERATION_RATE_CHANGE, LAB_RATE_CHANGE, LAB_RATE_CREATED, PLAN_CANCELLED, PLAN_MODIFIED
  severity   String   @default("INFO") // INFO, FLAG
  actorId    Int
  actor      Doctor   @relation(fields: [actorId], references: [id])
  patientId  Int?
  visitId    Int?
  entityType String   // Visit, Operation, LabRate, TreatmentPlan
  entityId   Int?
  reason     String?
  details    String?  // JSON stringified
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([severity])
  @@map("audit_logs")
}

// ============================================
// ESCROW PAYMENTS
// ============================================

model PatientPayment {
  id            Int                 @id @default(autoincrement())
  patientId     Int
  patient       Patient             @relation(fields: [patientId], references: [id])
  receiptNo     Int?
  amount        Float
  paymentMode   String              @default("Cash")
  paymentDate   DateTime
  notes         String?
  appointmentId Int?
  appointment   Appointment?        @relation(fields: [appointmentId], references: [id])
  createdById   Int
  createdBy     Doctor              @relation(fields: [createdById], references: [id])
  createdAt     DateTime            @default(now())
  fulfillments  EscrowFulfillment[]

  @@index([patientId])
  @@map("patient_payments")
}

model EscrowFulfillment {
  id              Int              @id @default(autoincrement())
  patientId       Int
  patient         Patient          @relation(fields: [patientId], references: [id])
  workDoneId      Int              @unique
  workDone        WorkDone         @relation(fields: [workDoneId], references: [id])
  visitId         Int
  visit           Visit            @relation(fields: [visitId], references: [id])
  amount          Float
  doctorId        Int?
  doctor          Doctor?          @relation(fields: [doctorId], references: [id])
  paymentId       Int?
  payment         PatientPayment?  @relation(fields: [paymentId], references: [id])
  fulfilledAt     DateTime         @default(now())

  @@index([patientId])
  @@index([visitId])
  @@index([workDoneId])
  @@map("escrow_fulfillments")
}
